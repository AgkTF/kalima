# Database connection (SQLite file path)
DATABASE_URL=file:./prisma/dev.db

# Server port
PORT=3001

# LLM API (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepinfra.com/v1/openai
LLM_CHEAP_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
LLM_PREMIUM_MODEL=google/gemma-4-31B-it

# Dev: force all enrichments to return "low" confidence (for QA/testing)
# Uncomment to test the flagged → premium → pending_review pipeline
# LLM_FORCE_CONFIDENCE=low

# Directory containing built frontend static files (only used in production)
# STATIC_DIR=/var/www/kalima