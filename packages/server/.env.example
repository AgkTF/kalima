# Database connection (SQLite file path)
DATABASE_URL=file:./prisma/dev.db

# Server port
PORT=3001

# LLM API (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHEAP_MODEL=gpt-4o-mini

# Directory containing built frontend static files (only used in production)
# STATIC_DIR=/var/www/kalima