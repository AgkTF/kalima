datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model AppMeta {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Capture {
  id        Int     @id @default(autoincrement())
  rawText   String
  item      String
  locator   String?
  sourceHint String?
  sessionId Int?
  createdAt DateTime @default(now())

  session   Session? @relation(fields: [sessionId], references: [id])
  entry     Entry?
}

model Source {
  id   Int    @id @default(autoincrement())
  name String
  type String

  sessions Session[]

  @@unique([name, type])
}

model Session {
  id                  Int       @id @default(autoincrement())
  sourceId            Int
  createdAt           DateTime  @default(now())
  closedAt            DateTime?
  /// Per-session enrichment prompt template override.
  /// When set, used instead of the global default. Pre-filled from global default at session creation.
  enrichmentTemplate  String?

  source   Source    @relation(fields: [sourceId], references: [id])
  captures Capture[]
}

model Entry {
  id                 Int      @id @default(autoincrement())
  captureId          Int      @unique
  status             String   @default("pending_review")
  definition         String
  translationArabic  String
  nuance             String
  examples           String
  tags               String
  /// Stores item names from LLM enrichment output.
  /// OPEN DECISION: Some names may not resolve to existing Entries.
  /// Keep as unresolved references (display differently in UI) or drop on resolution?
  /// Decide in Word Bank slice.
  relatedEntries     String
  /// JSON array of field names flagged as wrong on rejection.
  /// Example: ["definition", "translationArabic"]
  flaggedFields      String?
  /// Free-form note explaining why the enrichment was rejected.
  rejectionNote      String?
  /// Self-assessed confidence from the enrichment agent: "high" or "low"
  confidence          String?
  enrichedAt         DateTime @default(now())

  capture            Capture  @relation(fields: [captureId], references: [id], onDelete: Cascade)
}